<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Tamil:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdn.sheetjs.com/xlsx-latest/package/dist/xlsx.full.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

<style>
:root{ --bd:#0a2463;--bm:#1e4fc2;--bl:#3a86ff; --gr:#0d9e6e;--rd:#dc2626; --bg:#f0f4ff;--card:#fff;--tx:#0f172a;--mu:#64748b; --br:#dbe4ff;--ra:14px;--sh:0 4px 24px rgba(10,36,99,.10); } 
*{box-sizing:border-box;margin:0;padding:0} 
body{font-family:'Noto Sans Tamil',sans-serif;background:var(--bg);color:var(--tx);min-height:100vh;overscroll-behavior-y:none} 
.screen{display:none;min-height:100vh;animation:fi .3s ease} 
.screen.active{display:flex;flex-direction:column} 
@keyframes fi{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}} 

/* LOGIN */ 
#ls{background:linear-gradient(145deg,#0a2463,#1e4fc2,#3a86ff);align-items:center;justify-content:center;padding:20px} 
.lb{background:#fff;border-radius:24px;padding:32px 28px;width:100%;max-width:400px;box-shadow:0 20px 60px rgba(10,36,99,.3)} 
.li{width:68px;height:68px;background:linear-gradient(135deg,var(--bd),var(--bl));border-radius:18px;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;font-size:30px} 
.lb h1{font-size:20px;font-weight:800;color:var(--bd);text-align:center} 
.lb p{font-size:11px;color:var(--mu);text-align:center;margin-top:3px;margin-bottom:20px} 
.rt{display:flex;gap:6px;background:#f1f5f9;border-radius:10px;padding:4px;margin-bottom:18px} 
.rb{flex:1;padding:8px;border:none;border-radius:7px;cursor:pointer;font-family:inherit;font-size:13px;font-weight:600;color:var(--mu);background:transparent;transition:.2s} 
.rb.on{background:#fff;color:var(--bd);box-shadow:0 2px 8px rgba(0,0,0,.1)} 
.fg{margin-bottom:14px} 
.fg label{display:block;font-size:12px;font-weight:700;color:var(--bd);margin-bottom:5px} 
.fg input{width:100%;padding:11px 13px;border:2px solid var(--br);border-radius:10px;font-family:inherit;font-size:13px;outline:none;transition:.2s;background:#f8faff} 
.fg input:focus{border-color:var(--bl);background:#fff} 
.bl{width:100%;padding:13px;background:linear-gradient(135deg,var(--bd),var(--bm));color:#fff;border:none;border-radius:12px;font-family:inherit;font-size:15px;font-weight:700;cursor:pointer;box-shadow:0 4px 16px rgba(30,79,194,.4)} 

/* APP */ 
.ah{background:linear-gradient(135deg,var(--bd),var(--bm));color:#fff;padding:0 16px;display:flex;align-items:center;gap:10px;height:58px;position:sticky;top:0;z-index:100;box-shadow:0 2px 12px rgba(10,36,99,.3)} 
.at{font-size:15px;font-weight:800;flex:1}.as{font-size:10px;opacity:.8;display:block} 
.hb{background:rgba(255,255,255,.15);border:none;color:#fff;width:34px;height:34px;border-radius:8px;cursor:pointer;font-size:15px;display:flex;align-items:center;justify-content:center} 
.ab{flex:1;padding:10px 2px;display:flex;flex-direction:column;align-items:center;cursor:pointer;border:none;background:transparent;font-family:inherit;color:var(--mu);font-size:9px;gap:2px} 
.ni{font-size:18px}.ab.on{color:var(--bm)} 
.nb{background:#fff;border-top:1px solid var(--br);display:flex;position:fixed;bottom:0;left:0;right:0;z-index:99;box-shadow:0 -2px 12px rgba(10,36,99,.08)} 
.body{flex:1;padding:14px;max-width:900px;margin:0 auto;width:100%;padding-bottom:90px} 

/* CARDS */ 
.card{background:var(--card);border-radius:var(--ra);padding:16px;box-shadow:var(--sh);margin-bottom:12px;border:1px solid rgba(219,228,255,.6)} 
.st{font-size:11px;font-weight:800;color:var(--mu);text-transform:uppercase;letter-spacing:.8px;margin-bottom:10px;padding-bottom:6px;border-bottom:2px solid var(--br)} 

/* BANNER */ 
.ban{background:linear-gradient(135deg,var(--bd),var(--bl));color:#fff;border-radius:16px;padding:18px;margin-bottom:12px;position:relative;overflow:hidden} 
.ban::after{content:'🍚';position:absolute;right:12px;bottom:-8px;font-size:56px;opacity:.12} 
.ban h2{font-size:17px;font-weight:800}.ban p{font-size:11px;opacity:.85;margin-top:3px} 
.bdg{display:inline-block;background:rgba(255,255,255,.2);border-radius:6px;padding:2px 10px;font-size:10px;margin-top:6px} 

/* STATS */ 
.sg{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-bottom:12px} 
.sc{background:#fff;border-radius:12px;padding:14px;text-align:center;box-shadow:var(--sh);border:1px solid rgba(219,228,255,.6);cursor:pointer} 
.si{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px;margin:0 auto 8px} 
.sv{font-size:22px;font-weight:800;color:var(--bd)}.sl{font-size:10px;color:var(--mu);margin-top:2px} 

/* ACTION */ 
.ag{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;margin-bottom:12px} 
.an{padding:13px 10px;border:none;border-radius:12px;cursor:pointer;font-family:inherit;font-size:12px;font-weight:700;color:#fff;display:flex;flex-direction:column;gap:5px;align-items:flex-start;box-shadow:0 4px 12px rgba(0,0,0,.15)} 
.ai{font-size:22px} 

/* STOCK DISPLAY */ 
.stg{display:grid;grid-template-columns:repeat(2,1fr);gap:8px} 
.si2{border-radius:10px;padding:10px 12px;display:flex;justify-content:space-between;align-items:center;border:1px solid} 
.ok{background:#f0fdf4;border-color:#86efac} 
.lo{background:#fef2f2;border-color:#fca5a5} 
.wa{background:#fffbeb;border-color:#fcd34d} 
.sn{font-size:12px;font-weight:700}.sv2{font-size:15px;font-weight:800} 
.ok .sv2{color:var(--gr)}.lo .sv2{color:var(--rd)}.wa .sv2{color:#b45309} 
.sa{font-size:9px;color:var(--rd);font-weight:700;margin-top:1px} 

/* FORM */ 
.fr{display:grid;gap:8px;margin-bottom:10px} 
.c2{grid-template-columns:repeat(2,1fr)}.c3{grid-template-columns:repeat(3,1fr)} 
.fgs label{display:block;font-size:10px;font-weight:700;color:var(--mu);margin-bottom:4px;text-transform:uppercase;letter-spacing:.4px} 
.fgs input,.fgs select{width:100%;padding:9px 11px;border:2px solid var(--br);border-radius:9px;font-family:inherit;font-size:13px;color:var(--tx);outline:none;transition:.2s;background:#f8faff} 
.fgs input:focus{border-color:var(--bl);background:#fff} 

/* TABLES RESPONSIVE */
.table-res { overflow-x: auto; -webkit-overflow-scrolling: touch; border-radius: 8px; }

/* ENTRY TABLE ROWS */ 
.etr td{padding:7px 6px;border-bottom:1px solid rgba(0,0,0,.05);vertical-align:middle; white-space:nowrap} 
.etr:last-child td{border-bottom:none} 
.etr td:first-child{padding-left:10px;font-size:12px;font-weight:700;color:var(--tx)} 
.stk-val{font-size:13px;font-weight:800;color:var(--gr);text-align:center} 
.stk-val.low{color:var(--rd)} 
.rem-val{font-size:13px;font-weight:800;color:var(--bm);text-align:center} 
.rem-val.low{color:var(--rd)} 
.use-inp{width:100%;min-width:60px;padding:7px 8px;border:2px solid #fed7aa;border-radius:8px;font-family:inherit;font-size:13px;font-weight:700;text-align:center;color:#92400e;background:#fff8f0;outline:none} 
.use-inp:focus{border-color:#c2410c;background:#fff} 

/* STRIPS */ 
.strip{border-radius:10px;padding:12px;margin-bottom:10px} 
.gr-strip{background:#fff8f0;border:1px solid #fed7aa} 
.mo-strip{background:#f0fdf4;border:1px solid #bbf7d0} 
.strip-t{font-size:12px;font-weight:800;margin-bottom:8px;display:flex;align-items:center;gap:6px;flex-wrap:wrap} 

/* PREVIEW */ 
.ps{border-radius:12px;overflow:hidden;margin-bottom:10px;border:1px solid} 
.ph{padding:9px 14px;font-size:12px;font-weight:800} 
.pb{padding:12px 14px} 
.pr{display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid rgba(0,0,0,.04)} 
.pr:last-child{border-bottom:none} 
.pl{font-size:12px;color:var(--mu)}.pv{font-size:12px;font-weight:700} 
.pv.hi{color:var(--bm);font-size:14px} 

/* REPORT */ 
.rf{display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap;align-items:center} 
.rf select{padding:9px 12px;border:2px solid var(--br);border-radius:9px;font-family:inherit;font-size:12px;background:#fff;outline:none} 
.chips{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px} 
.chip{background:#fff;border:1px solid var(--br);border-radius:16px;padding:5px 12px;font-size:11px;font-weight:700;color:var(--bd);white-space:nowrap} 
.chip span{color:var(--bl)} 
.tw{overflow-x:auto;border-radius:12px;border:1px solid var(--br); background:#fff; -webkit-overflow-scrolling:touch} 
table{width:100%;border-collapse:collapse;min-width:max-content} 
thead tr{background:linear-gradient(135deg,var(--bd),var(--bm))} 
th{color:#fff;padding:10px 7px;font-size:10px;text-align:center;white-space:nowrap} 
td{padding:9px 7px;font-size:11px;text-align:center;border-bottom:1px solid #f1f5f9;white-space:nowrap} 
tr:nth-child(even) td{background:#f8faff} 
tr:hover td{background:#eef2ff} 

/* BAL CARD */ 
.bc{border-radius:16px;padding:16px;margin-bottom:10px} 
.bg2{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:10px} 
.bb{border-radius:10px;padding:10px;text-align:center} 
.bv2{font-size:16px;font-weight:800;margin:4px 0} 
.bn{font-size:10px;opacity:.85}.bu{font-size:9px;opacity:.7;margin-top:1px} 

/* BTNS */ 
.bp{background:linear-gradient(135deg,var(--bd),var(--bm));color:#fff;border:none;border-radius:11px;padding:12px 18px;font-family:inherit;font-size:14px;font-weight:700;cursor:pointer;width:100%;box-shadow:0 4px 14px rgba(30,79,194,.3)} 
.bs{background:#fff;color:var(--bd);border:2px solid var(--bl);border-radius:11px;padding:11px 18px;font-family:inherit;font-size:14px;font-weight:700;cursor:pointer} 
.bg{background:linear-gradient(135deg,#065f46,var(--gr));color:#fff;border:none;border-radius:11px;padding:12px 18px;font-family:inherit;font-size:14px;font-weight:700;cursor:pointer;width:100%} 
.be{background:var(--bl);color:#fff;border:none;border-radius:7px;padding:5px 9px;font-size:11px;cursor:pointer} 
.bd2{background:var(--rd);color:#fff;border:none;border-radius:7px;padding:5px 9px;font-size:11px;cursor:pointer} 

/* EMPTY */ 
.em{text-align:center;padding:36px 16px} 
.em .ei{font-size:48px;opacity:.5;margin-bottom:10px} 
.em p{color:var(--mu);font-size:13px} 

/* TOAST & MODAL */ 
.toast{position:fixed;bottom:76px;left:50%;transform:translateX(-50%) translateY(16px);background:#0f172a;color:#fff;border-radius:10px;padding:11px 22px;font-size:13px;font-weight:600;z-index:9999;opacity:0;transition:.3s;pointer-events:none;white-space:nowrap} 
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)} 
.toast.ok{background:linear-gradient(135deg,#065f46,var(--gr))} 
.toast.err{background:linear-gradient(135deg,#7f1d1d,var(--rd))} 
.mb{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:200;align-items:center;justify-content:center;padding:20px} 
.mb.open{display:flex} 
.md{background:#fff;border-radius:20px;padding:26px 22px;max-width:360px;width:100%;text-align:center} 
.md h3{font-size:17px;font-weight:800;margin-bottom:6px;color:var(--bd)} 
.md p{font-size:13px;color:var(--mu);margin-bottom:18px} 
.mdb{display:flex;gap:8px} 
@media(max-width:480px){.c3{grid-template-columns:repeat(2,1fr)}} 
</style>
</head>
<body>

<div id="ls" class="screen active">
    <div class="lb">
        <div class="li">🍚</div>
        <h1>சத்துணவு பதிவேடு</h1>
        <p>புரட்சி தலைவர் MGR சத்துணவு திட்டம்</p>
        <div class="rt">
            <button class="rb on" onclick="setRole('Admin')">👑 Admin</button>
            <button class="rb" onclick="setRole('User')">👤 பயனர்</button>
        </div>
        <div class="fg">
            <label>பள்ளி பெயர் (Username)</label>
            <input type="text" id="lS" placeholder="உம்: PUMS கோவில்பட்டி">
        </div>
        <div class="fg">
            <label>கடவுச்சொல் (Password)</label>
            <input type="password" id="lP" placeholder="பள்ளி பெயரையே உள்ளிடவும்">
        </div>
        <button class="bl" onclick="doLogin()">உள்நுழை →</button>
    </div>
</div>

<div id="ap" class="screen">
    <header class="ah">
        <div class="li" style="width:36px;height:36px;font-size:18px;margin:0">🍚</div>
        <div class="at">சத்துணவு பதிவேடு <span class="as" id="hS">பள்ளி</span></div>
        <button class="hb" onclick="doLogout()">🚪</button>
    </header>

    <div class="body">
        <div id="pD" class="page"> 
            <div class="ban">
                <h2 id="dSch">பள்ளி</h2><p id="dDt">இன்று</p><div class="bdg" id="dRl">👤</div>
            </div> 
            <div class="sg" id="sGrid"></div> 
            <div class="st">⚡ விரைவு செயல்கள்</div> 
            <div class="ag"> 
                <button class="an" style="background:linear-gradient(135deg,#1e3a8a,#1e4fc2)" onclick="gP('entry')"><span class="ai">➕</span>புதிய பதிவு</button> 
                <button class="an" style="background:linear-gradient(135deg,#14532d,#16a34a)" onclick="gP('stock')"><span class="ai">📦</span>இருப்பு Update</button> 
                <button class="an" style="background:linear-gradient(135deg,#065f46,#0d9e6e)" onclick="gP('report')"><span class="ai">📊</span>அறிக்கை</button> 
                <button class="an" style="background:linear-gradient(135deg,#7c2d12,#ea580c)" onclick="doExcel()"><span class="ai">📥</span>Excel Download</button> 
                <button class="an" style="background:linear-gradient(135deg,#475569,#64748b)" onclick="backupData()"><span class="ai">💾</span>Backup Data</button> 
                <button class="an" style="background:linear-gradient(135deg,#94a3b8,#cbd5e1);color:#0f172a" onclick="document.getElementById('importFile').click()"><span class="ai">📂</span>Restore Data</button>
                <input type="file" id="importFile" accept=".json" style="display:none" onchange="restoreData(event)">
            </div> 
            <div class="st">🏪 தற்போதைய இருப்பு நிலை</div> 
            <div id="dStock"></div> 
        </div> 

        <div id="pE" class="page" style="display:none"> 
            <div class="card"> 
                <div style="display:flex;align-items:center;gap:8px;margin-bottom:14px"> 
                    <span style="font-size:18px">📋</span> 
                    <h3 style="font-size:14px;font-weight:800;color:var(--bd)" id="eTitle">புதிய பதிவு</h3> 
                </div> 
                <div class="st">பொது தகவல்</div> 
                <div class="fr c2"> 
                    <div class="fgs"><label>தேதி *</label><input type="date" id="fDt"></div> 
                    <div class="fgs"><label>மாதம் *</label> 
                        <select id="fMo" style="width:100%;padding:9px 11px;border:2px solid var(--br);border-radius:9px;font-family:inherit;font-size:13px;background:#f8faff;outline:none;color:var(--tx)"> 
                            <option>ஜனவரி</option><option>பிப்ரவரி</option><option>மார்ச்</option><option>ஏப்ரல்</option> 
                            <option>மே</option><option>ஜூன்</option><option>ஜூலை</option><option>ஆகஸ்ட்</option> 
                            <option>செப்டம்பர்</option><option>அக்டோபர்</option><option>நவம்பர்</option><option>டிசம்பர்</option> 
                        </select> 
                    </div> 
                </div> 
                <div class="fgs" style="margin-bottom:14px"><label>உண்ணும் மாணவர்கள் *</label><input type="number" id="fSt" placeholder="52" min="0"></div> 
                
                <div class="strip gr-strip" style="padding:0;overflow:hidden"> 
                    <div style="background:#c2410c;padding:10px 14px;color:#fff;font-size:12px;font-weight:800"> 
                        🌾 தானியங்கள் & முட்டை — இருப்பு அளவு / இன்று பயன்பாடு / மீதம் 
                    </div> 
                    <div class="table-res">
                        <table style="width:100%;border-collapse:collapse;min-width:380px;"> 
                            <thead> 
                                <tr style="background:#fff3e4"> 
                                    <th style="padding:8px 10px;font-size:10px;font-weight:800;color:#92400e;text-align:left;width:32%">பொருள்</th> 
                                    <th style="padding:8px 6px;font-size:10px;font-weight:800;color:#065f46;text-align:center;width:22%">📦 இருப்பு</th> 
                                    <th style="padding:8px 6px;font-size:10px;font-weight:800;color:#c2410c;text-align:center;width:24%">🔥 பயன்பாடு</th> 
                                    <th style="padding:8px 6px;font-size:10px;font-weight:800;color:#1e4fc2;text-align:center;width:22%">✅ மீதம்</th> 
                                </tr> 
                            </thead> 
                            <tbody id="grainTbody"></tbody> 
                        </table> 
                    </div>
                </div> 

                <div class="strip mo-strip" style="padding:0;overflow:hidden;margin-top:10px"> 
                    <div style="background:#065f46;padding:10px 14px;color:#fff;font-size:12px;font-weight:800"> 
                        💰 தினசரி செலவுகள் (₹) 
                    </div> 
                    <div style="padding:12px">
                        <div class="fr c3">
                            <div class="fgs"><label>🥦 காய்கறி</label><input type="number" id="uV" placeholder="0" min="0" oninput="calcM()"></div>
                            <div class="fgs"><label>🛍️ மளிகை</label><input type="number" id="uG" placeholder="0" min="0" oninput="calcM()"></div>
                            <div class="fgs"><label>🪵 எரிபொருள்</label><input type="number" id="uF" placeholder="0" min="0" oninput="calcM()"></div>
                        </div>
                        <div style="display:flex;justify-content:space-between;align-items:center;background:#dcfce7;padding:10px 14px;border-radius:8px;margin-top:10px;border:1px solid #bbf7d0">
                            <div style="font-size:12px;font-weight:700;color:#065f46">மொத்த செலவு: <span style="font-size:16px;font-weight:800">₹<span id="totM">0</span></span></div>
                            <div style="font-size:12px;font-weight:700;color:#1e4fc2">இருப்பு மீதம்: <span style="font-size:16px;font-weight:800">₹<span id="remM">0</span></span></div>
                        </div>
                    </div>
                </div> 
                
                <div class="fr c2" style="margin-bottom:14px;margin-top:10px"> 
                    <div class="fgs"><label>📝 குறிப்பு</label><input type="text" id="fRm" placeholder="Normal"></div> 
                </div> 
                <div style="display:flex;gap:8px"> 
                    <button class="bs" style="flex:1" onclick="gP('dash')">↩ ரத்து</button> 
                    <button class="bp" style="flex:2" onclick="gPrev()">Preview காண் →</button> 
                </div> 
            </div> 
        </div> 

        <div id="pP" class="page" style="display:none"> 
            <div id="pvC"></div> 
            <div style="display:flex;gap:8px;margin-top:4px"> 
                <button class="bs" style="flex:1" onclick="gP('entry')">✏️ திருத்து</button> 
                <button class="bg" style="flex:2" onclick="saveEntry()">✅ உறுதிப்படுத்து & சேமி</button> 
            </div> 
        </div> 

        <div id="pS" class="page" style="display:none"> 
