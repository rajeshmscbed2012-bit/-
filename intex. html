<script>
// ============ PWA SERVICE WORKER ============
if ('serviceWorker' in navigator) {
    const sw = `
    self.addEventListener('install', e => self.skipWaiting());
    self.addEventListener('activate', e => self.clients.claim());
    self.addEventListener('fetch', e => {
        e.respondWith(fetch(e.request).catch(() => new Response('App is offline. Please check your connection.')));
    });`;
    const blob = new Blob([sw], {type: 'application/javascript'});
    navigator.serviceWorker.register(URL.createObjectURL(blob)).then(()=>console.log('PWA Ready'));
}

// ============ CONFIG ============ 
const GRAINS=[ 
    {k:'R', lbl:'🌾 அரிசி', unit:'kg', low:10, iId:'iR', uId:'uR'}, 
    {k:'D', lbl:'🫘 பருப்பு', unit:'kg', low:3, iId:'iD', uId:'uD'}, 
    {k:'O', lbl:'🫙 எண்ணெய்', unit:'L', low:2, iId:'iO', uId:'uO'}, 
    {k:'C', lbl:'🫛 கொண்டைக்கடலை', unit:'kg', low:2, iId:'iC', uId:'uC'}, 
    {k:'M', lbl:'🌿 பாசிப்பருப்பு', unit:'kg', low:2, iId:'iM', uId:'uM'}, 
    {k:'Sa',lbl:'🧂 உப்பு', unit:'kg', low:1, iId:'iSa',uId:'uSa'}, 
    {k:'Eg',lbl:'🥚 முட்டை', unit:'எண்', low:50, iId:'iEg',uId:'uEg'} 
]; 
const MONEY=[ {k:'Amt', lbl:'💰 தொகை இருப்பு', unit:'₹', low:500, iId:'iAmt'} ]; 
const MONTHS=['ஜனவரி','பிப்ரவரி','மார்ச்','ஏப்ரல்','மே','ஜூன்','ஜூலை','ஆகஸ்ட்','செப்டம்பர்','அக்டோபர்','நவம்பர்','டிசம்பர்']; 

// Formatting helper (No decimals for Eggs/Nos)
const fN = (v, u) => u === 'எண்' ? v.toFixed(0) : v.toFixed(2);

// ============ STATE ============ 
let S={ 
    user:'',role:'Admin',school:'', 
    entries:JSON.parse(localStorage.getItem('mdm_e')||'[]'), 
    stocks: JSON.parse(localStorage.getItem('mdm_s')||'[]'), 
    editId:null,delId:null,delType:'e',page:'dash' 
}; 

// ============ BALANCE ============ 
function bal(){ 
    const sc=S.school; 
    const b={}; 
    [...GRAINS,...MONEY].forEach(x=>{ 
        const totalIn =S.stocks.filter(s=>s.sc===sc).reduce((t,s)=>t+(s['i'+x.k]||0),0); 
        const totalOut=S.entries.filter(e=>e.sc===sc).reduce((t,e)=>t+(e['u'+x.k]||0),0); 
        b[x.k]=totalIn-totalOut; 
    }); 
    return b; 
} 

// ============ AUTH & NAV ============ 
function setRole(r){ S.role=r; document.querySelectorAll('.rb').forEach((b,i)=>b.classList.toggle('on',(i===0&&r==='Admin')||(i===1&&r==='User'))); } 
function doLogin(){ 
    const sc=document.getElementById('lS').value.trim();
    const p=document.getElementById('lP').value.trim(); 
    if(!sc||!p){toast('அனைத்தையும் நிரப்பவும்','err');return;} 
    if(sc !== p){toast('கடவுச்சொல் தவறானது! பள்ளி பெயரையே கடவுச்சொல்லாக உள்ளிடவும்.','err');return;} 
    S.user=sc; S.school=sc; document.getElementById('hS').textContent=sc; 
    document.getElementById('ls').classList.remove('active'); document.getElementById('ap').classList.add('active'); 
    init(); 
} 
function doLogout(){ document.getElementById('ap').classList.remove('active'); document.getElementById('ls').classList.add('active'); } 
function gP(p){ 
    document.querySelectorAll('.page').forEach(x=>x.style.display='none'); document.querySelectorAll('.ab').forEach(x=>x.classList.remove('on')); 
    S.page=p; 
    if(p==='dash'){ show('pD');actN('nD');loadDash();} 
    if(p==='entry'){ show('pE');actN('nE');if(!S.editId)initEntry(); } 
    if(p==='preview'){show('pP');} 
    if(p==='stock'){ show('pS');actN('nS');renderBal();initStock();loadHist();} 
    if(p==='report'){show('pR');actN('nR');document.getElementById('fMn').value=MONTHS[new Date().getMonth()];loadRpt();} 
} 
function show(id){document.getElementById(id).style.display='block';} 
function actN(id){document.getElementById(id).classList.add('on');} 

function init(){ 
    const t=new Date(); 
    document.getElementById('dSch').textContent=S.school; 
    document.getElementById('dDt').textContent=`இன்று: ${t.toLocaleDateString('ta-IN',{weekday:'long',year:'numeric',month:'long',day:'numeric'})}`; 
    document.getElementById('dRl').textContent=S.role==='Admin'?'👑 Admin':'👤 பயனர்'; 
    gP('dash'); 
} 

// ============ DASHBOARD ============ 
function loadDash(){ 
    const mn=MONTHS[new Date().getMonth()]; 
    const es=S.entries.filter(e=>e.sc===S.school&&e.mo===mn); 
    const tD=es.length,tSt=es.reduce((s,e)=>s+e.st,0); 
    const tR=es.reduce((s,e)=>s+(e.uR||0),0),tEg=es.reduce((s,e)=>s+(e.uEg||0),0); 
    document.getElementById('sGrid').innerHTML=` 
        <div class="sc" onclick="gP('report')"><div class="si" style="background:#dbeafe">📅</div><div class="sv">${tD}</div><div class="sl">${mn} பணி நாட்கள்</div></div> 
        <div class="sc"><div class="si" style="background:#dcfce7">👨‍👩‍👧‍👦</div><div class="sv">${tSt}</div><div class="sl">மொத்த மாணவர்கள்</div></div> 
        <div class="sc"><div class="si" style="background:#ffedd5">🌾</div><div class="sv">${tR.toFixed(1)}</div><div class="sl">அரிசி பயன்பாடு (kg)</div></div> 
        <div class="sc"><div class="si" style="background:#f3e8ff">🥚</div><div class="sv">${tEg}</div><div class="sl">முட்டை எண்ணிக்கை</div></div>`; 
    const b=bal(); 
    const all=[...GRAINS,...MONEY]; 
    document.getElementById('dStock').innerHTML=`<div class="stg">${all.map(x=>{ 
        const v=b[x.k]||0, isLow=v<=x.low, isWarn=v<=x.low*2&&v>x.low, cls=isLow?'lo':isWarn?'wa':'ok'; 
        const disp=x.unit==='₹'?`₹${v.toFixed(0)}`: `${fN(v, x.unit)} ${x.unit}`; 
        return `<div class="si2 ${cls}"><div><div class="sn">${x.lbl}</div>${isLow?'<div class="sa">⚠️ குறைவு!</div>':''}</div><div class="sv2">${disp}</div></div>`; 
    }).join('')}</div>`; 
} 

// ============ ENTRY & SPLIT CALCULATION ============ 
function calcM(){
    const v = parseFloat(document.getElementById('uV').value)||0;
    const g = parseFloat(document.getElementById('uG').value)||0;
    const f = parseFloat(document.getElementById('uF').value)||0;
    const tot = v + g + f;
    document.getElementById('totM').textContent = tot.toFixed(0);
    
    const stock = bal()['Amt'] || 0;
    const rem = stock - tot;
    const remEl = document.getElementById('remM');
    remEl.textContent = rem.toFixed(0);
    remEl.style.color = rem < 0 ? '#dc2626' : '#1e4fc2';
}

function calcG(){
    const b = bal();
    GRAINS.forEach(g => {
        const stock = b[g.k] || 0;
        const used = parseFloat(document.getElementById(g.uId)?.value) || 0;
        const rem = stock - used;
        const remEl = document.getElementById('rem_' + g.k);
        if(remEl) {
            remEl.textContent = fN(rem, g.unit);
            remEl.className = 'rem-val ' + (rem < 0 ? 'low' : '');
        }
    });
}

function initEntry(){ 
    S.editId=null; document.getElementById('eTitle').textContent='புதிய பதிவு'; 
    document.getElementById('fDt').value=new Date().toISOString().split('T')[0]; document.getElementById('fMo').value=MONTHS[new Date().getMonth()]; 
    document.getElementById('fRm').value='Normal'; 
    ['uV','uG','uF'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
    renderEntryTables(); // Build HTML once
    GRAINS.forEach(x=>{ const el=document.getElementById(x.uId); if(el) el.value=''; }); 
    calcG();
    calcM();
} 

function renderEntryTables(){ 
    const b=bal(); 
    document.getElementById('grainTbody').innerHTML=GRAINS.map(g=>{ 
        const stock=b[g.k]||0;
        const cv = document.getElementById(g.uId)?.value || ''; // Get current value if exists
        const used = parseFloat(cv)||0;
        const rem = stock-used; 
        return `<tr class="etr"><td>${g.lbl} <span style="font-size:9px;color:var(--mu);font-weight:500">(${g.unit})</span></td> 
            <td class="stk-val ${stock<=g.low?'low':''}">${fN(stock, g.unit)}</td> 
            <td><input type="number" class="use-inp" id="${g.uId}" placeholder="0" step="0.01" min="0" value="${cv}" oninput="calcG()"></td> 
            <td class="rem-val ${rem<0?'low':''}" id="rem_${g.k}">${fN(rem, g.unit)}</td></tr>`; 
    }).join(''); 
} 

function fData(){ 
    const g=id=>parseFloat(document.getElementById(id)?.value)||0; 
    const d={ id:S.editId||Date.now().toString(), dt:document.getElementById('fDt').value, mo:document.getElementById('fMo').value, 
        sc:S.school, st:parseInt(document.getElementById('fSt').value)||0, 
        rm:document.getElementById('fRm').value||'Normal', by:S.user,at:new Date().toISOString() }; 
    GRAINS.forEach(gr=>d['u'+gr.k]=g(gr.uId)); 
    d.uV = g('uV'); d.uG = g('uG'); d.uF = g('uF');
    d.uAmt = d.uV + d.uG + d.uF;
    return d; 
} 

function gPrev(){ 
    if(!document.getElementById('fDt').value||!document.getElementById('fSt').value){toast('தேதி மற்றும் மாணவர் எண்ணிக்கை கட்டாயம்','err');return;} 
    const d=fData(),b=bal(); 
    const sec=(ttl,hc,hbg,rows)=>`<div class="ps" style="border-color:${hc}44;margin-bottom:10px"><div class="ph" style="background:${hbg};color:${hc}">${ttl}</div> 
        <div class="pb">${rows.map(r=>`<div class="pr"><span class="pl">${r[0]}</span><span class="pv ${r[2]?'hi':''}">${r[1]||'—'}</span></div>`).join('')}</div></div>`; 
    const gRows=GRAINS.map(g=>{ const used=d['u'+g.k]||0, rem=(b[g.k]||0)-used; return [`${g.lbl} பயன்`,`${used} ${g.unit} → மீதம்: ${fN(rem, g.unit)} ${g.unit}`, used>0]; }); 
    const mRows=[
        ['🥦 காய்கறி',`₹${d.uV}`,d.uV>0],
        ['🛍️ மளிகை',`₹${d.uG}`,d.uG>0],
        ['🪵 எரிபொருள்',`₹${d.uF}`,d.uF>0],
        ['💰 மொத்த செலவு',`₹${d.uAmt} (மீதம்: ₹${((b['Amt']||0)-d.uAmt).toFixed(0)})`,d.uAmt>0]
    ];
    document.getElementById('pvC').innerHTML= 
        sec('📋 பொது தகவல்','#1e4fc2','#dbeafe',[['தேதி',d.dt,true],['பள்ளி',S.school],['மாதம்',d.mo],['மாணவர்கள்',d.st+' பேர்',true]])+ 
        sec('🌾 தானியங்கள் & முட்டை','#c2410c','#ffedd5',gRows)+ 
        sec('💰 செலவு','#065f46','#f0fdf4',mRows)+ 
        sec('📝 குறிப்பு','#4338ca','#eef2ff',[['தகவல்',d.rm]]); 
    gP('preview'); 
} 

function saveEntry(){ 
    const d=fData(); 
    if(S.editId){const i=S.entries.findIndex(e=>e.id===S.editId);if(i>=0)S.entries[i]=d;} else S.entries.push(d); 
    localStorage.setItem('mdm_e',JSON.stringify(S.entries)); S.editId=null; 
    document.getElementById('mT').textContent='வெற்றி!'; document.getElementById('mMsg').textContent=`${d.dt} பதிவு சேமிக்கப்பட்டது`; document.getElementById('mOk').classList.add('open'); 
} 
function closeMOk(){document.getElementById('mOk').classList.remove('open');gP('dash');} 

// ============ STOCK ============ 
function renderBal(){ 
    const b=bal(); 
    const gHtml=GRAINS.map(g=>{ const v=b[g.k]||0,low=v<=g.low; return `<div class="bb" style="background:rgba(255,255,255,${low?.25:.18})"><div style="font-size:16px">${g.lbl.split(' ')[0]}</div><div class="bv2" style="color:${low?'#fde68a':'#fff'}">${fN(v, g.unit)}</div><div class="bn">${g.lbl.replace(/^[^\s]+\s/,'')}</div><div class="bu">${g.unit}${low?' ⚠️':''}</div></div>`; }).join(''); 
    const mHtml=MONEY.map(m=>{ const v=b[m.k]||0,low=v<=m.low; return `<div class="bb" style="background:rgba(255,255,255,${low?.25:.18})"><div style="font-size:16px">${m.lbl.split(' ')[0]}</div><div class="bv2" style="color:${low?'#fde68a':'#fff'}">₹${v.toFixed(0)}</div><div class="bn">${m.lbl.replace(/^[^\s]+\s/,'')}</div><div class="bu">${low?'⚠️ குறைவு':''}</div></div>`; }).join(''); 
    document.getElementById('sBal').innerHTML=`<div class="bc" style="background:linear-gradient(135deg,#0a2463,#1e4fc2)"><div style="color:#fff;font-size:13px;font-weight:800;opacity:.9">🌾 தானியங்கள் & முட்டை இருப்பு</div><div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:10px">${gHtml}</div></div><div class="bc" style="background:linear-gradient(135deg,#065f46,#0d9e6e)"><div style="color:#fff;font-size:13px;font-weight:800;opacity:.9">💰 தொகை இருப்பு (₹)</div><div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:10px">${mHtml}</div></div>`; 
} 
function initStock(){ 
    document.getElementById('sDt').value=new Date().toISOString().split('T')[0]; ['iR','iD','iO','iC','iM','iSa','iEg','iAmt'].forEach(id=>{document.getElementById(id).value='';}); document.getElementById('sSp').value='';document.getElementById('sRm').value=''; 
} 
function saveStock(){ 
    const dt=document.getElementById('sDt').value; if(!dt){toast('தேதி தேர்ந்தெடுக்கவும்','err');return;} 
    const g=id=>parseFloat(document.getElementById(id)?.value)||0; 
    const rec={id:Date.now().toString(),dt,sc:S.school,sp:document.getElementById('sSp').value||'—',rm:document.getElementById('sRm').value||'—',by:S.user,at:new Date().toISOString()}; 
    GRAINS.forEach(gr=>rec['i'+gr.k]=g(gr.iId)); MONEY.forEach(m=>rec['i'+m.k]=g(m.iId)); 
    if(![...GRAINS,...MONEY].some(x=>rec['i'+x.k]>0)){toast('குறைந்தது ஒரு அளவு கொடுக்கவும்','err');return;} 
    S.stocks.push(rec); localStorage.setItem('mdm_s',JSON.stringify(S.stocks)); toast('✅ இருப்பு சேமிக்கப்பட்டது!','ok'); initStock();renderBal();loadHist(); 
} 
function loadHist(){ 
    const list=S.stocks.filter(s=>s.sc===S.school).slice().reverse(); const el=document.getElementById('sHist'),em=document.getElementById('sEmp'); 
    if(!list.length){el.innerHTML='';em.style.display='block';return;} em.style.display='none'; 
    el.innerHTML=list.map(s=>{ 
        const gp=GRAINS.map(g=>s['i'+g.k]>0?`${g.lbl}: <b>${fN(s['i'+g.k], g.unit)} ${g.unit}</b>`:'').filter(Boolean).join(' | '); 
        const mp=MONEY.map(m=>s['i'+m.k]>0?`${m.lbl}: <b>₹${s['i'+m.k]}</b>`:'').filter(Boolean).join(' | '); 
        return `<div class="card" style="padding:12px;margin-bottom:8px"><div style="display:flex;justify-content:space-between;margin-bottom:8px"><div><div style="font-weight:800;font-size:13px;color:var(--bd)">📅 ${s.dt}</div><div style="font-size:10px;color:var(--mu)">🏪 ${s.sp} | 👤 ${s.by}</div></div>${S.role==='Admin'?`<button class="bd2" onclick="delStock('${s.id}')">🗑️</button>`:''}</div>${gp?`<div style="font-size:11px;color:#92400e;background:#fef3c7;border-radius:7px;padding:6px 10px;margin-bottom:6px">${gp}</div>`:''}${mp?`<div style="font-size:11px;color:#065f46;background:#f0fdf4;border-radius:7px;padding:6px 10px;margin-bottom:6px">${mp}</div>`:''}${s.rm!=='—'?`<div style="font-size:10px;color:var(--mu)">📝 ${s.rm}</div>`:''}</div>`; 
    }).join(''); 
} 

// ============ REPORT ============ 
function loadRpt(){ 
    const mn=document.getElementById('fMn').value, es=S.entries.filter(e=>e.sc===S.school&&e.mo===mn); 
    const bd=document.getElementById('rBody'),em=document.getElementById('rEmp'); 
    if(!es.length){bd.innerHTML='';em.style.display='block';document.getElementById('sCh').innerHTML='';document.getElementById('rBal').innerHTML='';return;} 
    em.style.display='none'; const b=bal(); 
    
    document.getElementById('sCh').innerHTML=[`நாட்கள்: <span>${es.length}</span>`,`மாணவர்: <span>${es.reduce((s,e)=>s+e.st,0)}</span>`,...GRAINS.map(g=>`${g.lbl}: <span>${fN(es.reduce((s,e)=>s+(e['u'+g.k]||0),0), g.unit)} ${g.unit}</span>`),...MONEY.map(m=>`${m.lbl} இருப்பு: <span>₹${(b[m.k]||0).toFixed(0)}</span>`)].map(c=>`<div class="chip">${c}</div>`).join(''); 
    document.getElementById('rBal').innerHTML=`<div style="background:linear-gradient(135deg,#0a2463,#1e4fc2);border-radius:12px;padding:12px;color:#fff"><div style="font-size:12px;font-weight:800;opacity:.85;margin-bottom:8px">📊 தற்போதைய இருப்பு (Running Balance)</div><div style="display:flex;flex-wrap:wrap;gap:8px">${[...GRAINS,...MONEY].map(x=>{ const v=b[x.k]||0,low=v<=x.low; return `<span style="background:rgba(255,255,255,${low?.3:.15});border-radius:8px;padding:4px 10px;font-size:11px;font-weight:700;color:${low?'#fde68a':'#fff'}">${x.lbl} ${x.unit==='₹'?`₹${v.toFixed(0)}`:`${fN(v, x.unit)} ${x.unit}`}${low?' ⚠️':''}</span>`; }).join('')}</div></div>`; 
        
    bd.innerHTML=es.map(e=>`<tr><td><b>${e.dt}</b></td><td>${e.st}</td>${GRAINS.map(g=>`<td>${e['u'+g.k]||0}</td>`).join('')}
        <td>${e.uV||0}</td><td>${e.uG||0}</td><td>${e.uF||0}</td><td><b>₹${e.uAmt||0}</b></td>
        <td>${e.rm}</td><td class="no-print">${S.role==='Admin'?`<button class="be" onclick="editE('${e.id}')">✏️</button> <button class="bd2" onclick="openDel('${e.id}','e','${e.dt}')">🗑️</button>`:'—'}</td></tr>`).join(''); 
} 

function editE(id){ 
    const e=S.entries.find(x=>x.id===id);if(!e)return; S.editId=id; 
    document.getElementById('eTitle').textContent='பதிவு திருத்து'; document.getElementById('fDt').value=e.dt; document.getElementById('fMo').value=e.mo; 
    document.getElementById('fSt').value=e.st; document.getElementById('fRm').value=e.rm||'Normal'; 
    
    ['uV','uG','uF'].forEach(k=>{const el=document.getElementById(k);if(el)el.value=e[k]||'';});
    renderEntryTables(); 
    GRAINS.forEach(g=>{const el=document.getElementById(g.uId);if(el)el.value=e['u'+g.k]||'';}); 
    
    calcG();
    calcM();
    gP('entry'); 
} 

function openDel(id,type,lbl){S.delId=id;S.delType=type;document.getElementById('dMsg').textContent=`${lbl} பதிவை நீக்கவா?`;document.getElementById('mDl').classList.add('open');} 
function closeMDl(){document.getElementById('mDl').classList.remove('open');} 
function confDel(){ if(S.delType==='e'){S.entries=S.entries.filter(e=>e.id!==S.delId);localStorage.setItem('mdm_e',JSON.stringify(S.entries));loadRpt();} else{S.stocks=S.stocks.filter(s=>s.id!==S.delId);localStorage.setItem('mdm_s',JSON.stringify(S.stocks));renderBal();loadHist();} closeMDl();toast('நீக்கப்பட்டது','ok'); } 
function delStock(id){openDel(id,'s','இந்த இருப்பு');} 

// ============ DATA BACKUP / RESTORE / PDF / EXCEL ============ 
function backupData() {
    const dataStr = JSON.stringify({entries: S.entries, stocks: S.stocks}, null, 2);
    const a = document.createElement('a');
    a.href = URL.createObjectURL(new Blob([dataStr], { type: 'application/json' }));
    a.download = `MDM_Backup_${S.school}_${new Date().toISOString().split('T')[0]}.json`;
    document.body.appendChild(a); a.click(); document.body.removeChild(a); toast('✅ Backup தரவிறக்கம் செய்யப்பட்டது', 'ok');
}
function restoreData(event) {
    const file = event.target.files[0]; if (!file) return; const reader = new FileReader();
    reader.onload = function(e) { try { const data = JSON.parse(e.target.result); if (data.entries && data.stocks) { localStorage.setItem('mdm_e', JSON.stringify(data.entries)); localStorage.setItem('mdm_s', JSON.stringify(data.stocks)); S.entries = data.entries; S.stocks = data.stocks; toast('✅ Data மீட்கப்பட்டது!', 'ok'); loadDash(); document.getElementById('importFile').value = ''; } else { toast('❌ தவறான File format', 'err'); } } catch (err) { toast('❌ Error: File படிக்க முடியவில்லை', 'err'); } };
    reader.readAsText(file);
}
function downloadPDF() {
    document.querySelectorAll('.no-print').forEach(el => el.style.display = 'none');
    html2pdf().set({ margin:0.3, filename:`${document.getElementById('fMn').value}_${S.school}_MDM_Report.pdf`, image:{type:'jpeg',quality:0.98}, html2canvas:{scale:2,useCORS:true}, jsPDF:{unit:'in',format:'a4',orientation:'landscape'} }).from(document.getElementById('reportContentToPrint')).save().then(() => { toast('✅ PDF Download வெற்றி!', 'ok'); document.querySelectorAll('.no-print').forEach(el => el.style.display = ''); });
}
function doExcel(){ 
    const mn=S.page==='report'?document.getElementById('fMn').value:MONTHS[new Date().getMonth()], es=S.entries.filter(e=>e.sc===S.school&&e.mo===mn); 
    if(!es.length){toast('Export-க்கு data இல்லை','err');return;} 
    const hdr=['தேதி','மாணவர்',...GRAINS.map(g=>g.lbl+' ('+g.unit+')'),'🥦 காய்கறி (₹)','🛍️ மளிகை (₹)','🪵 எரிபொருள் (₹)','💰 மொத்த செலவு (₹)','குறிப்பு']; 
    const rows=[ [`புரட்சி தலைவர் MGR சத்துணவு திட்டம் - ${mn} - ${S.school}`],[],hdr, ...es.map(e=>[e.dt,e.st,...GRAINS.map(g=>e['u'+g.k]||0), e.uV||0, e.uG||0, e.uF||0, e.uAmt||0, e.rm]), 
        [],['மொத்தம்',es.reduce((s,e)=>s+e.st,0),...GRAINS.map(g=>es.reduce((s,e)=>s+(e['u'+g.k]||0),0).toFixed(g.unit==='எண்'?0:2)),es.reduce((s,e)=>s+(e.uV||0),0).toFixed(0),es.reduce((s,e)=>s+(e.uG||0),0).toFixed(0),es.reduce((s,e)=>s+(e.uF||0),0).toFixed(0),es.reduce((s,e)=>s+(e.uAmt||0),0).toFixed(0),''], 
    ]; 
    const wb=XLSX.utils.book_new(),ws=XLSX.utils.aoa_to_sheet(rows); ws['!cols']=Array(hdr.length).fill({wch:16}); ws['!merges']=[{s:{r:0,c:0},e:{r:0,c:hdr.length-1}}]; 
    XLSX.utils.book_append_sheet(wb,ws,`${mn} MDM`); XLSX.writeFile(wb,`${mn}_${S.school}_MDM.xlsx`); toast('✅ Excel Download வெற்றி!','ok'); 
} 

function toast(msg,type=''){ const t=document.getElementById('tst');t.textContent=msg;t.className=`toast ${type} show`; setTimeout(()=>t.className='toast',2800); } 

